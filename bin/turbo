#!/bin/bash

# NAS Build Accelerator: unified 'turbo' wrapper
# ---------------------------------------------
# One-command access to all our high-performance build tools.

PROJECT_ROOT=$(pwd)
CCACHE_PATH="$PROJECT_ROOT/.ccache"
RAM_DISK="/tmp/nas_build_ram"

show_help() {
    echo "NAS Turbo-Charge Tool"
    echo "Usage: ./bin/turbo [command]"
    echo ""
    echo "Commands:"
    echo "  setup    - Initialize RAM disks and C-cache folders"
    echo "  build    - Run high-speed eBPF build (uses ccache)"
    echo "  scrub    - Clean Docker build context (speed up copying)"
    echo "  clean    - Remove all build artifacts and RAM disks"
}

setup() {
    echo "[*] Setting up Turbo environment..."
    # 1. Bootstrap Stage 1: Build basic bin tools
    if [ ! -f "./bin/dependency_sideloader" ]; then
        echo "[*] Bootstrapping stage 1 via Docker..."
        sudo docker run --rm -v "$(pwd)":/app ebpf-builder /bin/bash -c "gcc -O3 /app/bin/dependency_sideloader.c -o /app/bin/dependency_sideloader -lcurl"
    fi

    # 2. Sideload dependencies
    if [ -f "./bin/dependency_sideloader" ]; then
        ./bin/dependency_sideloader
    fi

    # 3. Setup C-Cache and remaining tools
    mkdir -p "$CCACHE_PATH"
    echo "[*] Initializing remaining build tools..."
    sudo docker run --rm -v "$(pwd)":/app ebpf-builder /bin/bash -c "make build-nas-tools"
    # 3. Pre-fetch packages in parallel
    ./bin/pkg_warrior
    # 4. Setup RAM Disk if sudo available
    if [ "$EUID" -eq 0 ]; then
        ./bin/ram_disk_accelerator
        ./bin/fs_overdrive
    else
        echo "[!] Sudo required for RAM disks. Skipping some optimizations."
    fi
    echo "[SUCCESS] Turbo setup complete."
}

build() {
    echo "[*] Launching Turbo Build (eBPF + C-Tools)..."
    # Auto-create cache dir if it's missing
    mkdir -p "$CCACHE_PATH"
    
    # Enable BuildKit for faster builds
    export DOCKER_BUILDKIT=1

    # Ensure sideloader is built
    if [ ! -f "./bin/dependency_sideloader" ]; then
        echo "[!] Accelerators not found. Bootstrapping stage 1 (bin tools only)..."
        sudo docker run --rm -v "$(pwd)":/app ebpf-builder /bin/bash -c "gcc -O3 /app/bin/dependency_sideloader.c -o /app/bin/dependency_sideloader -lcurl"
    fi

    # Sideload missing dependencies instantly
    if [ -f "./bin/dependency_sideloader" ]; then
        ./bin/dependency_sideloader
    fi

    # Surgical Fix: Link NAS's own libpcap if available
    mkdir -p "$PROJECT_ROOT/deps"
    if [ -f "/usr/lib/x86_64-linux-gnu/libpcap.so.0.8" ]; then
        ln -sf "/usr/lib/x86_64-linux-gnu/libpcap.so.0.8" "$PROJECT_ROOT/deps/libpcap.so"
    elif [ -f "/lib/x86_64-linux-gnu/libpcap.so.0.8" ]; then
        ln -sf "/lib/x86_64-linux-gnu/libpcap.so.0.8" "$PROJECT_ROOT/deps/libpcap.so"
    elif [ -f "/usr/lib/libpcap.so" ]; then
        ln -sf "/usr/lib/libpcap.so" "$PROJECT_ROOT/deps/libpcap.so"
    fi
    
    echo "[*] Bootstrapping stage 2 (full build)..."
    sudo docker run --rm \
        -v "$PROJECT_ROOT":/app \
        -v "$CCACHE_PATH":/root/.ccache \
        -e CCACHE_DIR=/root/.ccache \
        ebpf-builder /bin/bash -c "make -C vps_kernel_proxy all && make build-nas-tools"
}

scrub() {
    ./bin/ctx_cleaner
}

case "$1" in
    setup) setup ;;
    build) build ;;
    scrub) scrub ;;
    *) show_help ;;
esac
