{
  "manifest_version": 3,
  "name": "Tianditu Hybrid Accelerator",
  "version": "1.9",
  "description": "Fast multi-source proxy failover and session cleaning with NAS Tile Cache.",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "offscreen",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "cookies",
    "browsingData"
  ],
  "host_permissions": [
    "https://freeproxy.world/*",
    "https://*.freeproxy.world/*",
    "https://databay.com/*",
    "https://*.databay.com/*",
    "*://*.tianditu.gov.cn/*",
    "*://*.tianditu.cn/*",
    "http://10.0.0.169:8082/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_title": "Tianditu Accelerator Status"
  },
  "icons": {
    "128": "icon.png"
  }
}
