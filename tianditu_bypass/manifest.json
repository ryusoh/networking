{
  "manifest_version": 3,
  "name": "Tianditu Hybrid Accelerator",
  "version": "1.6",
  "description": "Fast-path spoofing with automatic multi-source proxy failover.",
  "permissions": ["proxy", "storage", "alarms", "offscreen", "webRequest", "declarativeNetRequest"],
  "host_permissions": [
    "https://freeproxy.world/*",
    "https://*.freeproxy.world/*",
    "https://databay.com/*",
    "https://*.databay.com/*",
    "*://*.tianditu.gov.cn/*",
    "*://*.tianditu.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "128": "icon.png"
  }
}
