FROM python:3.12-slim

RUN apt-get update && apt-get install -y gcc && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Compile tile_storage.c into shared library
COPY tile_storage.c .
RUN gcc -shared -fPIC -O2 -o libtilestorage.so tile_storage.c

COPY tile_cache.py .

EXPOSE 8082

CMD ["python3", "tile_cache.py"]
