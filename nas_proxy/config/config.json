{
  "log": {
    "access": "/var/log/v2ray/access.log",
    "error": "/var/log/v2ray/error.log",
    "loglevel": "warning"
  },
  "dns": {
    "servers": [
      "223.5.5.5",
      "119.29.29.29",
      "8.8.8.8"
    ]
  },
  "inbounds": [
    {
      "port": 1080,
      "protocol": "http",
      "settings": {
        "auth": "noauth",
        "udp": true
      }
    },
    {
      "port": 8080,
      "protocol": "http",
      "settings": {
        "allowTransparent": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "http",
      "settings": {
        "servers": [
          {
            "address": "183.6.7.103",
            "port": 4145
          }
        ]
      },
      "streamSettings": {
        "sockopt": {
          "connectionReuse": true,
          "tcpFastOpen": true
        }
      },
      "tag": "china-proxy"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "outboundTag": "china-proxy",
        "domain": [
          "domain:tianditu.gov.cn",
          "domain:tianditu.cn"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "network": "tcp,udp"
      }
    ]
  }
